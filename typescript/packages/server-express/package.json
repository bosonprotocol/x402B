{
  "name": "@bosonprotocol/x402-server-express",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Express adapter for @bosonprotocol/x402-server — middleware + mountable router for the Boson Protocol escrow scheme.",
  "repository": {
    "type": "git",
    "url": "https://github.com/bosonprotocol/x402B.git",
    "directory": "typescript/packages/server-express"
  },
  "homepage": "https://github.com/bosonprotocol/x402B/tree/main/typescript/packages/server-express",
  "bugs": {
    "url": "https://github.com/bosonprotocol/x402B/issues"
  },
  "keywords": [
    "x402",
    "boson-protocol",
    "escrow",
    "express",
    "middleware"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/postbuild.mjs",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@bosonprotocol/x402-core": "workspace:^",
    "@bosonprotocol/x402-server": "workspace:^"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "devDependencies": {
    "@bosonprotocol/x402-actions": "workspace:^",
    "@bosonprotocol/x402-evm": "workspace:^",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "@types/supertest": "^6.0.2",
    "express": "^4.21.2",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "viem": "^2.39.3",
    "vitest": "^2.1.8"
  }
}

{
  "name": "@bosonprotocol/x402-evm",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Boson Protocol EVM calldata builders for the x402 escrow scheme — inner-action ABI encoding for the commit step and the executeMetaTransaction outer envelope. Wraps @bosonprotocol/core-sdk for everything else.",
  "repository": {
    "type": "git",
    "url": "https://github.com/bosonprotocol/x402B.git",
    "directory": "typescript/packages/evm"
  },
  "homepage": "https://github.com/bosonprotocol/x402B/tree/main/typescript/packages/evm",
  "bugs": {
    "url": "https://github.com/bosonprotocol/x402B/issues"
  },
  "keywords": [
    "x402",
    "boson-protocol",
    "escrow",
    "evm",
    "meta-transaction",
    "calldata"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./actions": {
      "types": "./dist/cjs/actions/index.d.ts",
      "import": "./dist/esm/actions/index.js",
      "require": "./dist/cjs/actions/index.js"
    },
    "./envelope": {
      "types": "./dist/cjs/envelope/index.d.ts",
      "import": "./dist/esm/envelope/index.js",
      "require": "./dist/cjs/envelope/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/postbuild.mjs",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@bosonprotocol/common": "^1.32.2",
    "@bosonprotocol/core-sdk": "1.46.1",
    "@bosonprotocol/x402-core": "workspace:^",
    "viem": "^2.39.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

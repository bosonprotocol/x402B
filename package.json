{
  "name": "x402b",
  "version": "0.0.0",
  "private": true,
  "description": "Boson Protocol implementation of the x402-escrow-schema. Monorepo for @bosonprotocol/x402-* packages.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bosonprotocol/x402b.git"
  },
  "homepage": "https://github.com/bosonprotocol/x402b",
  "bugs": {
    "url": "https://github.com/bosonprotocol/x402b/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "publish:alpha": "node scripts/publish-alpha.mjs",
    "publish:latest": "node scripts/publish-latest.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@changesets/get-release-plan": "^4.0.16",
    "@changesets/read": "^0.6.7",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
